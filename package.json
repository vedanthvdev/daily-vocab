{
  "name": "daily-vocab",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@bacons/apple-targets": "^4.0.7",
    "@expo-google-fonts/libre-baskerville": "^0.4.3",
    "@expo-google-fonts/source-sans-3": "^0.4.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@xmldom/xmldom": "0.8.13",
    "babel-preset-expo": "~57.0.0",
    "expo": "~57.0.6",
    "expo-asset": "~57.0.5",
    "expo-audio": "~57.0.2",
    "expo-font": "~57.0.1",
    "expo-linear-gradient": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  },
  "overrides": {
    "@xmldom/xmldom": "0.8.13",
    "uuid": "11.1.1"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "node scripts/ensure-macos.js \"npm run ios\" && expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "content:validate": "tsx content/tools/validate-catalog.ts",
    "content:generate": "tsx content/tools/generate-full-catalogs.ts",
    "content:build-beginner": "tsx content/tools/build-beginner-catalog.ts",
    "content:build-intermediate-hard": "tsx content/tools/build-intermediate-hard-catalogs.ts",
    "content:scrub": "tsx content/tools/scrub-catalog-quality.ts",
    "content:sync-android": "mkdir -p modules/widget-bridge/android/src/main/assets/words && cp content/words/*.json modules/widget-bridge/android/src/main/assets/words/",
    "content:validate:strict": "tsx content/tools/validate-catalog.ts --strict-count",
    "ios:device": "node scripts/ensure-macos.js \"npm run ios:device\" && expo run:ios",
    "content:sync-ios-widget": "mkdir -p targets/DailyVocabWidget/assets && cp content/words/*.json targets/DailyVocabWidget/assets/",
    "prebuild:ios": "node scripts/ensure-macos.js \"npm run prebuild:ios\" && expo prebuild -p ios",
    "content:sync": "npm run content:sync-android && npm run content:sync-ios-widget"
  },
  "private": true
}
